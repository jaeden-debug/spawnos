# SpawnOS — Environment Variables
# Copy this file to .env.local and fill in your values.

# Supabase (required for auth + dashboard features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (required for AI Aquarium Assistant chat + Blueprint generator)
# Never expose this key client-side. Used only in /api/chat and /api/blueprint server routes.
OPENAI_API_KEY=

# OpenAI models (optional — sensible defaults applied if left blank).
# OPENAI_CHAT_MODEL powers the conversational AI assistant (/api/chat).
# OPENAI_BLUEPRINT_MODEL powers the JSON tank-blueprint generator (/api/blueprint).
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_BLUEPRINT_MODEL=gpt-4o-mini

# Blackwater Aquatics — Shopify customer sync (powers /signup → /api/blackwater/subscribe)
# Registers signups as Shopify customers with marketing consent (enrolls them in
# the store's email automations) and returns the first-order discount code.
#
# Setup:
#   1. Blackwater Shopify admin → Settings → Apps and sales channels → Develop apps
#      → Create an app → Admin API scopes: enable `write_customers` → Install →
#      reveal the Admin API access token.
#   2. Create the discount code in admin: Discounts → Create → e.g. 15% off,
#      "Limit to one use per customer". Code must match BLACKWATER_DISCOUNT_CODE.
#
# Leave these blank for local dev — the signup still returns the code, it just
# won't sync the customer to Shopify.
BLACKWATER_SHOPIFY_DOMAIN=your-store.myshopify.com
BLACKWATER_SHOPIFY_ADMIN_TOKEN=
BLACKWATER_DISCOUNT_CODE=SPAWNOS15

# Site URL (used for canonical URLs and OG tags)
NEXT_PUBLIC_SITE_URL=https://spawnos.app
